# ── Database ──
# PostgreSQL connection string. Update with your actual credentials.
DATABASE_URL=postgresql://assetflow_user:YOUR_PASSWORD@localhost:5432/assetflow

# ── Google OAuth ──
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── JWT ──
JWT_SECRET=replace-with-a-long-random-secret

# ── Email / Resend Configuration ──
# Set EMAIL_MODE=live to send real emails via Resend API.
# Set EMAIL_MODE=demo (or leave blank) to log emails to console only.
EMAIL_MODE=demo
RESEND_API_KEY=re_your_resend_api_key
MAIL_FROM=onboarding@resend.dev
ADMIN_EMAIL=admin@yourdomain.com

# ── AI Keys ──
GEMINI_API_KEY=your-gemini-api-key
GROQ_API_KEY=your-groq-api-key

# ── Multi-Channel Notifications ──
SMTP_HOST=your-smtp-host
SMTP_PORT=587
SMTP_USERNAME=your-smtp-username
SMTP_PASSWORD=your-smtp-password
SMTP_FROM=your-smtp-from-address

# Slack
SLACK_WEBHOOK_URL=your-slack-incoming-webhook-url

# Metabase
METABASE_SITE_URL=http://localhost:3001
METABASE_SECRET_KEY=your-metabase-secret-key
